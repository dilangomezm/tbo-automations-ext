{
  "manifest_version": 3,
  "name": "TBO Automations",
  "version": "4.0.3",
  "description": "Herramienta interna de automatización para optimizar flujos de trabajo en TBO y BasketballMonster.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js", "uiKit.js", "alertsAssistant.js", "creatorBoost.js", "DataExtraction.js",
        "betTicketAlert.js", "BasketballMonsterNews.js", "ManualMarkets.js", "OddsConverter.js",
        "creatorQuicksBB.js", "GolfTranslations.js", "translationTool.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
